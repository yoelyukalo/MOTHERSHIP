# === MOTHERSHIP CONFIG ===

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (send /start to your bot, then check updates)
TELEGRAM_CHAT_ID=your_chat_id_here

# Server port
PORT=3000

# Drop folder for file ingestion (relative to project root)
DROP_FOLDER=./inbox

# yt-dlp downloads folder (kept outside the watched inbox so the
# Telegram handler owns the processing flow without racing the watcher)
DOWNLOADS_FOLDER=./downloads

# Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API (platform.openai.com) — used for Whisper audio transcription
OPENAI_API_KEY=your_openai_key_here

# Vision settings
VISION_MODEL=claude-sonnet-4-20250514
VISION_FPS=0.5
VISION_MAX_FRAMES=30
VISION_DEFAULT_MODE=vision

# Audio settings
AUDIO_MODEL=whisper-1

# === Quantum Mirror v2 ===

# OpenAI embedding model (also uses OPENAI_API_KEY above)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# Claude model used for mirror + wiki synthesis
SYNTHESIS_MODEL=claude-opus-4-6

# Obsidian vault path for export (leave blank to skip export)
OBSIDIAN_VAULT_PATH=

# Health check schedule + decay
HEALTH_CHECK_INTERVAL_HOURS=168
DECAY_AFTER_DAYS=30
DECAY_STEP=0.1
MIN_CONFIDENCE=0.2

# Retrieval top-k
MIRROR_TOPK=5
WIKI_TOPK=5

# Minimum turn length (chars) before post-response synthesis fires
SYNTHESIS_MIN_CHARS=40

# Cosine similarity threshold for auto-wikilinks in Obsidian export
WIKILINK_SIM_THRESHOLD=0.75
